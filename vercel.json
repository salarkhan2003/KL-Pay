{
  "buildCommand": "vite build",
  "outputDirectory": "dist",
  "installCommand": "npm install",
  "framework": null,
  "functions": {
    "api/**/*.ts": {
      "runtime": "@vercel/node@5.6.15"
    }
  },
  "routes": [
    { "src": "/api/health",                   "dest": "/api/health" },
    { "src": "/api/payments/create-session",  "dest": "/api/payments/create-session" },
    { "src": "/api/payments/direct-pay",      "dest": "/api/payments/direct-pay" },
    { "src": "/api/payments/webhook",         "dest": "/api/payments/webhook" },
    { "src": "/api/webhooks/welcome",         "dest": "/api/webhooks/welcome" },
    { "src": "/api/webhooks/order",           "dest": "/api/webhooks/order" },
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
