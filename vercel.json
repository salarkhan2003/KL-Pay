{
  "buildCommand": "vite build",
  "outputDirectory": "dist",
  "installCommand": "npm install",
  "framework": null,
  "functions": {
    "api/**/*.ts": {
      "runtime": "@vercel/node@5.6.15"
    }
  },
  "rewrites": [
    { "source": "/api/health",                   "destination": "/api/health" },
    { "source": "/api/payments/create-session",  "destination": "/api/payments/create-session" },
    { "source": "/api/payments/direct-pay",      "destination": "/api/payments/direct-pay" },
    { "source": "/api/payments/webhook",         "destination": "/api/payments/webhook" },
    { "source": "/api/webhooks/welcome",         "destination": "/api/webhooks/welcome" },
    { "source": "/api/webhooks/order",           "destination": "/api/webhooks/order" },
    { "source": "/(.*)",                         "destination": "/index.html" }
  ]
}
