rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ──────────────────────────────────────────────────────────────

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Admin = hardcoded email OR role field in Firestore (covers anonymous dev login)
    function isAdmin() {
      return isAuthenticated() && (
        request.auth.token.email == "salarkhanpatan7861@gmail.com" ||
        (
          exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
        )
      );
    }

    function isMerchant() {
      return isAuthenticated() &&
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'merchant';
    }

    function isOutletMerchant(outletId) {
      return isAuthenticated() &&
             exists(/databases/$(database)/documents/outlets/$(outletId)) &&
             get(/databases/$(database)/documents/outlets/$(outletId)).data.merchantId == request.auth.uid;
    }

    function getUserRole() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid))
        ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role
        : 'student';
    }

    // ── Users ─────────────────────────────────────────────────────────────────
    match /users/{userId} {
      // Any authenticated user can read any profile (needed for merchant to see student info)
      allow read: if isAuthenticated();

      // Owner can create their own profile — relaxed for anonymous/dev users
      allow create: if isOwner(userId) &&
                       request.resource.data.uid == request.auth.uid &&
                       request.resource.data.role in ['student', 'merchant', 'admin'];

      // Owner or admin can update
      allow update: if isOwner(userId) || isAdmin();

      // Only admin can delete
      allow delete: if isAdmin();
    }

    // ── Outlets ───────────────────────────────────────────────────────────────
    match /outlets/{outletId} {
      // Anyone can read outlets (needed for home screen without login)
      allow read: if true;

      // Admin or authenticated merchant/owner can write outlet docs
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && (
        isAdmin() ||
        isOutletMerchant(outletId) ||
        // Allow assigning merchantId (dev outlet assignment)
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['merchantId'])
      );
      allow delete: if isAdmin();

      // ── Menu items ──────────────────────────────────────────────────────────
      match /menu/{itemId} {
        allow read: if true;
        allow write: if isAuthenticated() && (
          isAdmin() || isOutletMerchant(outletId)
        );
      }
    }

    // ── Orders ────────────────────────────────────────────────────────────────
    match /orders/{orderId} {
      allow read: if isAuthenticated() && (
        request.auth.uid == resource.data.studentId ||
        isOutletMerchant(resource.data.outletId) ||
        isAdmin()
      );

      allow create: if isAuthenticated() &&
                       request.resource.data.studentId == request.auth.uid;

      allow update: if isAuthenticated() && (
        // Student cancels own pending order
        (request.auth.uid == resource.data.studentId &&
         request.resource.data.status == 'cancelled' &&
         resource.data.status == 'pending') ||
        // Merchant updates status
        isOutletMerchant(resource.data.outletId) ||
        // Admin can do anything
        isAdmin()
      );

      allow delete: if isAuthenticated() && (
        request.auth.uid == resource.data.studentId ||
        isAdmin()
      );
    }

    // ── Transactions ──────────────────────────────────────────────────────────
    match /transactions/{txId} {
      allow read: if isAuthenticated() && (
        request.auth.uid == resource.data.studentId || isAdmin()
      );
      allow create: if isAuthenticated() &&
                       request.resource.data.studentId == request.auth.uid;
      allow update: if isAuthenticated() && (
        request.auth.uid == resource.data.studentId || isAdmin()
      );
    }

    // ── Support tickets ───────────────────────────────────────────────────────
    match /support/{ticketId} {
      allow read: if isAuthenticated() && (
        request.auth.uid == resource.data.userId || isAdmin()
      );
      allow create: if isAuthenticated() &&
                       request.resource.data.userId == request.auth.uid;
      allow update: if isAdmin();
    }
  }
}
